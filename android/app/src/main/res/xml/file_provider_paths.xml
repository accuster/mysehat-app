<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- ✅ External storage - Downloads folder (user-accessible) -->
    <external-path
        name="downloads"
        path="Download/" />
    
    <!-- ✅ External storage root -->
    <external-path
        name="external"
        path="." />
    
    <!-- ✅ App's external cache directory -->
    <external-cache-path
        name="external_cache"
        path="." />
    
    <!-- ✅ App's external files directory -->
    <external-files-path
        name="external_files"
        path="." />
    
    <!-- ✅ Internal cache -->
    <cache-path
        name="cache"
        path="." />
    
    <!-- ✅ Internal files -->
    <files-path
        name="files"
        path="." />
</paths>